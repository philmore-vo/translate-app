{
  "name": "engilink-dictionary",
  "version": "3.5.0",
  "description": "EngiLink Dictionary — AI-powered multilingual translation assistant with SRS",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win",
    "build:dir": "electron-builder --win --dir"
  },
  "author": "EngiLink",
  "license": "MIT",
  "build": {
    "appId": "com.engilink.dictionary",
    "productName": "EngiLink Dictionary",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/tray-icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/tray-icon.ico",
      "uninstallerIcon": "assets/tray-icon.ico",
      "installerHeaderIcon": "assets/tray-icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "EngiLink Dictionary",
      "include": "build/installer.nsh"
    },
    "files": [
      "main.js",
      "preload.js",
      "preload-dashboard.js",
      "preload-spotlight.js",
      "preload-snip.js",
      "overlay.html",
      "dashboard.html",
      "spotlight.html",
      "snip.html",
      "js/**/*",
      "css/**/*",
      "assets/**/*",
      "!assets/copy_debug.log",
      "!assets/copy.cs",
      "!node_modules/tesseract.js/docs/**",
      "!node_modules/tesseract.js/examples/**",
      "!node_modules/tesseract.js/dist/**",
      "!node_modules/tesseract.js/scripts/**",
      "!node_modules/tesseract.js-core/tesseract-core.js",
      "!node_modules/tesseract.js-core/tesseract-core.wasm",
      "!node_modules/tesseract.js-core/tesseract-core.wasm.js",
      "!node_modules/tesseract.js-core/tesseract-core-simd.js",
      "!node_modules/tesseract.js-core/tesseract-core-simd.wasm",
      "!node_modules/tesseract.js-core/tesseract-core-simd.wasm.js",
      "!node_modules/tesseract.js-core/tesseract-core-relaxedsimd.js",
      "!node_modules/tesseract.js-core/tesseract-core-relaxedsimd.wasm",
      "!node_modules/tesseract.js-core/tesseract-core-relaxedsimd.wasm.js"
    ],
    "afterPack": "scripts/afterPack.js",
    "extraResources": [
      {
        "from": ".",
        "to": ".",
        "filter": [
          "*.traineddata"
        ]
      }
    ],
    "asar": true,
    "asarUnpack": [
      "assets/copy.exe",
      "assets/copy.vbs"
    ]
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.1"
  },
  "dependencies": {
    "tesseract.js": "^7.0.0"
  }
}
