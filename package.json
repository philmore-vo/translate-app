{
  "name": "engilink-dictionary",
  "version": "2.0.0",
  "description": "EngiLink Dictionary — AI-powered multilingual translation assistant with SRS",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win",
    "build:dir": "electron-builder --win --dir"
  },
  "author": "EngiLink",
  "license": "MIT",
  "build": {
    "appId": "com.engilink.dictionary",
    "productName": "EngiLink Dictionary",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/tray-icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/tray-icon.ico",
      "uninstallerIcon": "assets/tray-icon.ico",
      "installerHeaderIcon": "assets/tray-icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "EngiLink Dictionary"
    },
    "files": [
      "main.js",
      "preload.js",
      "preload-dashboard.js",
      "preload-spotlight.js",
      "overlay.html",
      "dashboard.html",
      "spotlight.html",
      "js/**/*",
      "css/**/*",
      "assets/**/*",
      "!assets/copy_debug.log",
      "!assets/copy.cs"
    ],
    "extraResources": [],
    "asar": true
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^3.0.1"
  }
}
