{
  "name": "engilink-dictionary",
  "version": "3.5.0",
  "description": "EngiLink Dictionary — AI-powered multilingual translation assistant with SRS",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win",
    "build:dir": "electron-builder --win --dir"
  },
  "author": "EngiLink",
  "license": "MIT",
  "build": {
    "appId": "com.engilink.dictionary",
    "productName": "EngiLink Dictionary",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/tray-icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/tray-icon.ico",
      "uninstallerIcon": "assets/tray-icon.ico",
      "installerHeaderIcon": "assets/tray-icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "EngiLink Dictionary"
    },
    "files": [
      "main.js",
      "preload.js",
      "preload-dashboard.js",
      "preload-spotlight.js",
      "preload-snip.js",
      "overlay.html",
      "dashboard.html",
      "spotlight.html",
      "snip.html",
      "js/**/*",
      "css/**/*",
      "assets/**/*",
      "!assets/copy_debug.log",
      "!assets/copy.cs",
      "!node_modules/tesseract.js/docs/**",
      "!node_modules/tesseract.js/examples/**",
      "!node_modules/tesseract.js/dist/**",
      "!node_modules/tesseract.js/scripts/**"
    ],
    "afterPack": "scripts/afterPack.js",
    "extraResources": [
      {
        "from": ".",
        "to": ".",
        "filter": [
          "*.traineddata"
        ]
      }
    ],
    "asar": true,
    "asarUnpack": [
      "assets/copy.exe",
      "assets/copy.vbs",
      "node_modules/tesseract.js/**",
      "node_modules/tesseract.js-core/**",
      "node_modules/regenerator-runtime/**",
      "node_modules/bmp-js/**",
      "node_modules/is-url/**",
      "node_modules/node-fetch/**",
      "node_modules/wasm-feature-detect/**",
      "node_modules/zlibjs/**",
      "node_modules/idb-keyval/**",
      "node_modules/whatwg-url/**",
      "node_modules/tr46/**",
      "node_modules/webidl-conversions/**"
    ]
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.1"
  },
  "dependencies": {
    "tesseract.js": "^7.0.0",
    "tesseract.js-core": "^7.0.0"
  }
}
